# ──────────────────────────────────────────────
# Telegram Bot Credentials
# ──────────────────────────────────────────────
# Obtain from https://my.telegram.org/apps
API_ID=
API_HASH=

# Obtain from @BotFather
BOT_TOKEN=
BOT_USERNAME=LunarMovieBot

# ──────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
DB_NAME=lunar_movie_bot

# ──────────────────────────────────────────────
# TMDb
# ──────────────────────────────────────────────
# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ──────────────────────────────────────────────
# Channels & Admins
# ──────────────────────────────────────────────
# Comma-separated list of storage channel IDs (negative integers)
# Example: STORAGE_CHANNELS=-1001234567890,-1009876543210
STORAGE_CHANNELS=

# Channel for bot logs (optional)
LOG_CHANNEL=

# Comma-separated list of admin user IDs
ADMINS=

# ──────────────────────────────────────────────
# Behavior
# ──────────────────────────────────────────────
MAX_RESULTS=10

# Seconds before auto-deleting sent files (0 = never)
AUTO_DELETE_TIMEOUT=300

# Per-user flood protection
FLOOD_WAIT_SECONDS=2
MAX_REQUESTS_PER_MINUTE=20

# ──────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────
# Telegram support group link
SUPPORT_CHAT=

# Custom welcome image URL (Pexels recommended)
WELCOME_IMAGE=https://images.pexels.com/photos/7991579/pexels-photo-7991579.jpeg
